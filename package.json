{
	"name": "@framedash/cli",
	"version": "0.1.7",
	"description": "Framedash CLI: game telemetry queries, CI perf-regression gating (perf-diff, run-profile-test), and coding-agent integration for Unity, Unreal Engine 5, and Godot",
	"keywords": [
		"game-analytics",
		"game-telemetry",
		"performance",
		"performance-regression",
		"ci",
		"perf-diff",
		"profiling",
		"heatmap",
		"unity",
		"unreal-engine",
		"ue5",
		"godot",
		"clickhouse",
		"cli"
	],
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"framedash": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@framedash/api-client": "0.1.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.19.0",
		"@vitest/coverage-v8": "^3.2.6",
		"typescript": "^5.7.0",
		"vitest": "^3.2.6"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/crane-valley/framedash-cli.git"
	}
}
